@model IEnumerable<LiveDinner.Models.Sub_Category>

@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout - Admin.cshtml";
}

<h2>Index</h2>

<p>
    @Html.ActionLink("Create New", "Create")
</p>
<table class="table">
    <tr>
        <th>
            @Html.DisplayNameFor(model => model.Category.Category_Name)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Sub_Category_Name)
        </th>
        <th></th>
    </tr>

@foreach (var item in Model) {
    <tr>
        <td>
            @Html.DisplayFor(modelItem => item.Category.Category_Name)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Sub_Category_Name)
        </td>
        <td>
            @Html.ActionLink("Edit", "Edit", new { id=item.Sub_Category_ID }) |
            @Html.ActionLink("Details", "Details", new { id=item.Sub_Category_ID }) |
            @Html.ActionLink("Delete", "Delete", new { id=item.Sub_Category_ID })
        </td>
    </tr>
}

</table>
